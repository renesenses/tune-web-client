## Stage 1: Build
FROM node:22-alpine AS build

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts
COPY . .
RUN npm run build

## Stage 2: Serve with nginx (docker-compose variant)
FROM nginx:alpine

LABEL maintainer="renesenses"
LABEL description="Tune Web Client - Web interface for Tune Server"

RUN rm /etc/nginx/conf.d/default.conf
COPY nginx/docker.conf /etc/nginx/conf.d/tune-web-client.conf
COPY --from=build /app/dist /usr/share/tune-web-client

EXPOSE 80
